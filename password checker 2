history = []

while True:
    password = input("Enter your password: ")

    has_upper = False
    has_lower = False
    has_digit = False
    has_symbol = False

    for i in password:
        if i.isupper():
            has_upper = True
        elif i.islower():
            has_lower = True
        elif i.isdigit():
            has_digit = True
        else:
            has_symbol = True

    # Strength check
    if len(password) >= 8 and has_upper and has_lower and has_digit and has_symbol:
        print("💪 Strong password")
    else:
        print("❌ Weak password")

        # 🔥 YAHI ADD KARNA THA (inside else)
        if len(password) < 8:
            print("❌ Password too short")
        if not has_upper:
            print("❌ Uppercase missing")
        if not has_lower:
            print("❌ Lowercase missing")
        if not has_digit:
            print("❌ Digit missing")
        if not has_symbol:
            print("❌ Symbol missing")

    # history fix
    if password not in history:
        history.append(password)

    again = input("Try again? (yes/no): ").lower()
    if again != "yes":
        print("📜 History:", history)
        break
